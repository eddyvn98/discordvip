generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  PAID
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  MATCHED
  PENDING_REVIEW
  DUPLICATE
}

enum MembershipSource {
  PAID
  TRIAL
  MANUAL
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
}

enum Platform {
  DISCORD
  TELEGRAM
}

enum WebhookProcessStatus {
  RECEIVED
  PROCESSED
  DUPLICATE
  FAILED
}

enum ReferralEventStatus {
  JOINED
  SUCCESS
  FAILED
}

enum ReferralPointSource {
  INVITE_SUCCESS
  REDEEM_VIP
  ADMIN_ADJUST
}

model Plan {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  amount       Int
  durationDays Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
  telegramChannelMappings TelegramPlanChannel[]
}

model TelegramVipChannel {
  id        String   @id @default(cuid())
  chatId    String   @unique
  title     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  planMappings TelegramPlanChannel[]
}

model TelegramPlanChannel {
  id        String             @id @default(cuid())
  planId    String
  channelId String
  createdAt DateTime           @default(now())
  plan      Plan               @relation(fields: [planId], references: [id], onDelete: Cascade)
  channel   TelegramVipChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([planId, channelId])
}

model TelegramChannelVerification {
  id                      String    @id @default(cuid())
  token                   String    @unique
  requestedBy             String
  expiresAt               DateTime
  usedAt                  DateTime?
  verifiedByTelegramUserId String?
  verifiedChatId          String?
  verifiedChatTitle       String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}

model Order {
  id            String      @id @default(cuid())
  orderCode     String      @unique
  discordUserId String
  guildId       String
  platform      Platform    @default(DISCORD)
  platformUserId String?
  platformChatId String?
  amount        Int
  status        OrderStatus @default(PENDING)
  expiresAt     DateTime
  paidAt        DateTime?
  paymentPromptChatId String?
  paymentPromptMessageId Int?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  planId        String
  plan          Plan        @relation(fields: [planId], references: [id])
  payments      Payment[]
}

model Payment {
  id                    String        @id @default(cuid())
  provider              String        @default("sepay")
  providerTransactionId String        @unique
  amount                Int
  bankRef               String?
  transferContent       String?
  payerName             String?
  status                PaymentStatus @default(PENDING_REVIEW)
  matchedAt             DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  raw                   Json
  orderId               String?
  order                 Order?        @relation(fields: [orderId], references: [id])
}

model Membership {
  id            String           @id @default(cuid())
  discordUserId String
  guildId       String
  roleId        String
  platform      Platform         @default(DISCORD)
  platformUserId String?
  platformChatId String?
  source        MembershipSource
  status        MembershipStatus @default(ACTIVE)
  startAt       DateTime
  expireAt      DateTime
  reminded3dAt  DateTime?
  reminded1dAt  DateTime?
  removeRetries Int              @default(0)
  lastError     String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([discordUserId, guildId, roleId])
}

model PromoCode {
  id          String                @id @default(cuid())
  code        String                @unique
  label       String
  durationDays Int
  maxUses     Int
  usedCount   Int                   @default(0)
  expiresAt   DateTime?
  isActive    Boolean               @default(true)
  createdBy   String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  redemptions PromoCodeRedemption[]
}

model PromoCodeRedemption {
  id                 String     @id @default(cuid())
  promoCodeId        String
  platform           Platform   @default(DISCORD)
  platformUserId     String
  platformChatId     String?
  discordUserId      String
  durationDaysApplied Int
  redeemedAt         DateTime   @default(now())
  promoCode          PromoCode  @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, platform, platformUserId])
}

model TrialClaim {
  id            String   @id @default(cuid())
  discordUserId String   @unique
  platform      Platform @default(DISCORD)
  platformUserId String?
  claimedAt     DateTime @default(now())

  @@unique([platform, platformUserId])
}

model WebhookEvent {
  id              String               @id @default(cuid())
  provider        String               @default("sepay")
  providerEventId String?
  signature       String?
  payload         Json
  processStatus   WebhookProcessStatus @default(RECEIVED)
  errorMessage    String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model DiscordUserProfile {
  discordUserId  String   @id
  username       String
  globalName     String?
  discriminator  String
  avatar         String?
  displayName    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Session {
  sid    String   @id(map: "session_pkey") @db.VarChar
  sess   Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], map: "IDX_session_expire")
  @@map("session")
}

model ReferralSetting {
  id                    String   @id @default(cuid())
  pointsPerSuccess      Int      @default(10)
  daysPerPoint          Int      @default(1)
  verifyRequired        Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model ReferralInviteToken {
  id             String   @id @default(cuid())
  token          String   @unique
  platform       Platform
  inviterUserId  String
  inviterChatId  String?
  inviteLink     String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  events         ReferralInviteEvent[]
}

model ReferralInviteEvent {
  id               String              @id @default(cuid())
  platform         Platform
  inviterUserId    String
  inviteeUserId    String
  inviterChatId    String?
  inviteeChatId    String?
  inviteTokenId    String
  status           ReferralEventStatus @default(JOINED)
  verifiedAt       DateTime?
  failedReason     String?
  pointsAwarded    Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  inviteToken      ReferralInviteToken @relation(fields: [inviteTokenId], references: [id], onDelete: Cascade)
  redemptions      ReferralRedemption[]
  pointLedgers     ReferralPointLedger[]

  @@unique([platform, inviterUserId, inviteeUserId])
}

model ReferralPointLedger {
  id               String              @id @default(cuid())
  platform         Platform
  userId           String
  eventId          String?
  source           ReferralPointSource
  deltaPoints      Int
  note             String?
  createdAt        DateTime            @default(now())
  event            ReferralInviteEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)
}

model ReferralRedemption {
  id               String              @id @default(cuid())
  platform         Platform
  userId           String
  inviteEventId    String?
  pointsSpent      Int
  vipDaysGranted   Int
  membershipId     String?
  createdAt        DateTime            @default(now())
  event            ReferralInviteEvent? @relation(fields: [inviteEventId], references: [id], onDelete: SetNull)
}
